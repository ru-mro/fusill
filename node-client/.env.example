# Solana RPC — use devnet for testing, mainnet-beta for production
SOLANA_RPC_URL=https://api.devnet.solana.com

# Address of the deployed Fusill program (printed by scripts/deploy.sh)
PROGRAM_ID=<deployed program id>

# Node private key as a byte array (generate with: solana-keygen new)
# NEVER commit the real .env with the key — only this example file
NODE_KEYPAIR=[12,34,56,...]

# Minimum stake to deposit at registration (in lamports — 500000000 = 0.5 SOL)
STAKE_LAMPORTS=500000000

# How many seconds to wait between polls for available jobs
POLL_INTERVAL_SECONDS=5
